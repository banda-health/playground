# Development server configuration
VITE_PORT=3000
VITE_HOST=localhost

# Port the upload API listens on.
# Used by: Vite proxy (dev), nginx template (prod), and the API server itself.
API_PORT=3001

# Secret used to sign session cookies. Use a long random string in production.
# Generate one with: openssl rand -base64 32
SESSION_SECRET=your-session-secret-here

# Postgres connection string
# Docker (API in compose): set automatically via docker-compose.yml — do not override.
# Local API on host: expose postgres with `docker compose -f docker-compose.yml -f docker-compose.dev.yml up postgres -d`
#   then use: postgresql://playground:playground@localhost:5432/playground
DATABASE_URL=postgresql://playground:playground@localhost:5432/playground

# JetBrains Hub SSO
# Register your app as a Hub service and set the redirect URI to match HUB_REDIRECT_URI.
# HUB_URL must be the full Hub base URL, including any context path (e.g. /hub).
# For hub.bandahealth.org this is: https://hub.bandahealth.org/hub
HUB_URL=https://hub.example.com/hub
HUB_CLIENT_ID=your-hub-service-id
HUB_CLIENT_SECRET=your-hub-service-secret
# Dev: http://localhost:3000/api/auth/callback  |  Prod: https://your-domain/api/auth/callback
HUB_REDIRECT_URI=http://localhost:3000/api/auth/callback
# Optional — defaults to "0-0-0-0-0 <HUB_CLIENT_ID>" (Hub + your app service IDs)
# HUB_SCOPE=
# Set to true only if your Hub service has "Require PKCE" enabled (off by default for server-side apps)
# HUB_USE_PKCE=false

# Set to false only for local HTTP testing (production defaults to secure cookies)
# COOKIE_SECURE=false

# Development only — skip Hub SSO and auto sign in as a test user (ignored in production)
DEV_AUTH_BYPASS=true
# DEV_AUTH_USER_NAME=Dev User
# DEV_AUTH_USER_EMAIL=dev@localhost
