# Development server configuration
VITE_PORT=3000
VITE_HOST=localhost

# Port the upload API listens on.
# Used by: Vite proxy (dev), nginx template (prod), and the API server itself.
API_PORT=3001

# Shared password for the login screen. Required in production.
AUTH_PASSWORD=your-password-here

# Secret used to sign session cookies. Use a long random string in production.
# Generate one with: openssl rand -base64 32
SESSION_SECRET=your-session-secret-here
