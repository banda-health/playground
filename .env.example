# Development server configuration
VITE_PORT=3000
VITE_HOST=localhost

# Port the upload API listens on.
# Used by: Vite proxy (dev), nginx template (prod), and the API server itself.
API_PORT=3001

# Secret used to sign session cookies. Use a long random string in production.
# Generate one with: openssl rand -base64 32
SESSION_SECRET=your-session-secret-here

# Postgres connection string
# Local dev (with docker-compose postgres): postgresql://playground:playground@localhost:5432/playground
DATABASE_URL=postgresql://playground:playground@localhost:5432/playground

# JetBrains Hub SSO
# Register your app as a Hub service and set the redirect URI to match HUB_REDIRECT_URI.
HUB_URL=https://hub.example.com
HUB_CLIENT_ID=your-hub-service-id
HUB_CLIENT_SECRET=your-hub-service-secret
# Dev: http://localhost:3000/api/auth/callback  |  Prod: https://your-domain/api/auth/callback
HUB_REDIRECT_URI=http://localhost:3000/api/auth/callback
# Optional Hub OAuth scope (leave empty unless your Hub admin specifies one)
# HUB_SCOPE=

# Development only — skip Hub SSO and auto sign in as a test user (ignored in production)
DEV_AUTH_BYPASS=true
# DEV_AUTH_USER_NAME=Dev User
# DEV_AUTH_USER_EMAIL=dev@localhost
